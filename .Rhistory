library(caret)       # Data partitioning and evaluation
library(ggplot2)     # Data visualization
data <- read_csv2("saudi-arabia-traffic-accidents-and-casualties-injured-dead-2008.csv")
# Standardize column names
names(data) <- tolower(names(data))
names(data) <- gsub("\\.", "", names(data))
# Filter relevant indicators
accidents <- data %>%
filter(indicator %in% c("No. of Casualties - Injured", "No. of Casualties - Dead", "No. of Accidents")) %>%
select(year, region, indicator, value) %>%
pivot_wider(names_from = indicator, values_from = value) %>%
rename(injured = "No. of Casualties - Injured",
dead = "No. of Casualties - Dead",
accidents = "No. of Accidents")
# Remove missing values
accidents <- na.omit(accidents)
accidents$severity <- case_when(
accidents$injured / (accidents$injured + accidents$dead + accidents$accidents) > 0.5 ~ "injured",
accidents$dead / (accidents$injured + accidents$dead + accidents$accidents) > 0.5 ~ "dead",
accidents$accidents / (accidents$injured + accidents$dead + accidents$accidents) > 0.5 ~ "accidents",
TRUE ~ "mixed"
)
table(accidents$severity)  # Check category distribution
set.seed(123)
min_class_size <- min(table(accidents$severity))  # Get the smallest category count
balanced_data <- accidents %>%
group_by(severity) %>%
slice_sample(n = min_class_size)  # Sample same number from each category
table(balanced_data$severity)  # Verify balance
set.seed(123)  # For reproducibility
train_index <- createDataPartition(balanced_data$severity, p = 0.7, list = FALSE)
train_data <- balanced_data[train_index, ]
test_data <- balanced_data[-train_index, ]
normalize <- function(x) {
return ((x - min(x)) / (max(x) - min(x)))
}
train_features_norm <- as.data.frame(lapply(train_data[, c("injured", "dead", "accidents")], normalize))
test_features_norm <- as.data.frame(lapply(test_data[, c("injured", "dead", "accidents")], normalize))
train_labels <- factor(train_data$severity, levels = c("injured", "dead", "accidents"))
test_labels <- factor(test_data$severity, levels = c("injured", "dead", "accidents"))
knn_pred <- knn(train = train_features_norm,
test = test_features_norm,
cl = train_labels,
k = 3)
knn_pred <- factor(knn_pred, levels = levels(test_labels))
ggplot(train_data, aes(x = injured, y = dead, color = severity)) +
geom_point(size = 3) +
labs(title = "KNN Classification: Injured vs. Dead",
x = "Injured Casualties",
y = "Dead Casualties") +
scale_color_manual(values = c("injured" = "blue", "dead" = "red", "accidents" = "orange")) +
theme_minimal()
library(tidyverse)   # Data manipulation
library(class)       # KNN algorithm
library(caret)       # Data partitioning and evaluation
library(ggplot2)     # Data visualization
data <- read_csv2("saudi-arabia-traffic-accidents-and-casualties-injured-dead-2008.csv")
# Standardize column names
names(data) <- tolower(names(data))
names(data) <- gsub("\\.", "", names(data))
# Filter to keep only rows containing the key indicators, then pivot to get each indicator as a column
accidents <- data %>%
filter(indicator %in% c("No. of Casualties - Injured",
"No. of Casualties - Dead",
"No. of Accidents")) %>%
select(year, region, indicator, value) %>%
pivot_wider(names_from = indicator, values_from = value) %>%
rename(injured = "No. of Casualties - Injured",
dead = "No. of Casualties - Dead",
accidents = "No. of Accidents")
# Remove rows with missing values
accidents <- na.omit(accidents)
accidents$severity <- apply(accidents[, c("injured", "dead", "accidents")], 1, function(x) {
names(x)[which.max(x)]
})
# Check the distribution of the categories
table(accidents$severity)
#4
set.seed(123)
min_class_size <- min(table(accidents$severity))
balanced_data <- accidents %>%
group_by(severity) %>%
slice_sample(n = min_class_size) %>%   # Sample n records from each group
ungroup()
# Verify the balance
table(balanced_data$severity)
set.seed(123)  # For reproducibility
train_index <- createDataPartition(balanced_data$severity, p = 0.7, list = FALSE)
train_data <- balanced_data[train_index, ]
test_data  <- balanced_data[-train_index, ]
normalize <- function(x) {
(x - min(x)) / (max(x) - min(x))
}
train_features_norm <- as.data.frame(lapply(train_data[, c("injured", "dead", "accidents")], normalize))
test_features_norm  <- as.data.frame(lapply(test_data[, c("injured", "dead", "accidents")], normalize))
# Create factor labels with explicit levels
train_labels <- factor(train_data$severity, levels = c("injured", "dead", "accidents"))
test_labels  <- factor(test_data$severity, levels = c("injured", "dead", "accidents"))
knn_pred <- knn(train = train_features_norm,
test  = test_features_norm,
cl    = train_labels,
k     = 3)
# Ensure the predicted classes use the same factor levels
knn_pred <- factor(knn_pred, levels = levels(test_labels))
# Optionally, evaluate the prediction with a confusion matrix
conf_matrix <- confusionMatrix(knn_pred, test_labels)
print(conf_matrix)
ggplot(train_data, aes(x = injured, y = dead, color = severity)) +
geom_point(size = 3) +
labs(title = "Training Data: Injured vs. Dead by Severity",
x = "Injured Casualties",
y = "Dead Casualties") +
scale_color_manual(values = c("injured" = "blue", "dead" = "red", "accidents" = "orange")) +
theme_minimal()
# Load key libraries
library(tidyverse)  # Data manipulation
library(class)  # KNN algorithm
library(stats)  # General statistical functions
library(caret)  # Data partitioning and evaluation
data <- read_csv2("saudi-arabia-traffic-accidents-and-casualties-injured-dead-2008.csv")
names(data) <- tolower(names(data))  # Convert to lowercase
names(data) <- gsub("\\.", "", names(data))  # Remove special characters
head(data)  # Display first few rows
str(data)  # Structure of dataset
summary(data)  # Summary stats
accidents <- data %>%
filter(indicator %in% c("No. of Casualties - Injured", "No. of Casualties - Dead", "No. of Accidents")) %>%
select(year, region, indicator, value) %>%
pivot_wider(names_from = indicator, values_from = value) %>%
rename(injured = "No. of Casualties - Injured",
dead = "No. of Casualties - Dead",
accidents = "No. of Accidents")  # Adding accident count
accidents <- na.omit(accidents)
accidents$severity <- case_when(
accidents$injured + accidents$dead + accidents$accidents > quantile(accidents$injured + accidents$dead + accidents$accidents, 0.75) ~ "High",
accidents$injured + accidents$dead + accidents$accidents > median(accidents$injured + accidents$dead + accidents$accidents) ~ "Medium",
TRUE ~ "Low"
)
set.seed(123)  # Reproducibility
train_index <- createDataPartition(accidents$severity, p = 0.7, list = FALSE)
train_data <- accidents[train_index, ]
test_data <- accidents[-train_index, ]
normalize <- function(x) {
return ((x - min(x)) / (max(x) - min(x)))
}
train_features_norm <- as.data.frame(lapply(train_data[, c("injured", "dead", "accidents")], normalize))
test_features_norm <- as.data.frame(lapply(test_data[, c("injured", "dead", "accidents")], normalize))
train_labels <- factor(train_data$severity)
test_labels <- factor(test_data$severity)
knn_pred <- knn(train = train_features_norm,
test = test_features_norm,
cl = train_labels,
k = 3)  # Experiment with different k values
knn_pred <- factor(knn_pred, levels = levels(test_labels))
conf_matrix <- confusionMatrix(knn_pred, test_labels)
print(conf_matrix)
library(ggplot2)
ggplot(accidents, aes(x = injured, y = dead, color = severity)) +
geom_point(size = 3) +
labs(title = "Injured vs Dead Casualties by Severity",
x = "Injured Casualties",
y = "Dead Casualties") +
theme_minimal()
